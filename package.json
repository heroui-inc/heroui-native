{
  "name": "heroui-native",
  "version": "1.0.0-beta.12",
  "description": "Beautiful, fast and modern React Native UI library",
  "main": "./lib/module/index.js",
  "types": "./lib/typescript/src/index.d.ts",
  "source": "./src/index.tsx",
  "exports": {
    ".": {
      "source": "./src/index.tsx",
      "types": "./lib/typescript/src/index.d.ts",
      "default": "./lib/module/index.js"
    },
    "./styles": "./lib/module/styles/index.css",
    "./package.json": "./package.json",
    "./accordion": {
      "source": "./src/components/accordion/index.ts",
      "types": "./lib/typescript/src/components/accordion/index.d.ts",
      "default": "./lib/module/components/accordion/index.js"
    },
    "./avatar": {
      "source": "./src/components/avatar/index.ts",
      "types": "./lib/typescript/src/components/avatar/index.d.ts",
      "default": "./lib/module/components/avatar/index.js"
    },
    "./bottom-sheet": {
      "source": "./src/components/bottom-sheet/index.ts",
      "types": "./lib/typescript/src/components/bottom-sheet/index.d.ts",
      "default": "./lib/module/components/bottom-sheet/index.js"
    },
    "./button": {
      "source": "./src/components/button/index.ts",
      "types": "./lib/typescript/src/components/button/index.d.ts",
      "default": "./lib/module/components/button/index.js"
    },
    "./card": {
      "source": "./src/components/card/index.ts",
      "types": "./lib/typescript/src/components/card/index.d.ts",
      "default": "./lib/module/components/card/index.js"
    },
    "./checkbox": {
      "source": "./src/components/checkbox/index.ts",
      "types": "./lib/typescript/src/components/checkbox/index.d.ts",
      "default": "./lib/module/components/checkbox/index.js"
    },
    "./chip": {
      "source": "./src/components/chip/index.ts",
      "types": "./lib/typescript/src/components/chip/index.d.ts",
      "default": "./lib/module/components/chip/index.js"
    },
    "./description": {
      "source": "./src/components/description/index.ts",
      "types": "./lib/typescript/src/components/description/index.d.ts",
      "default": "./lib/module/components/description/index.js"
    },
    "./dialog": {
      "source": "./src/components/dialog/index.ts",
      "types": "./lib/typescript/src/components/dialog/index.d.ts",
      "default": "./lib/module/components/dialog/index.js"
    },
    "./divider": {
      "source": "./src/components/divider/index.ts",
      "types": "./lib/typescript/src/components/divider/index.d.ts",
      "default": "./lib/module/components/divider/index.js"
    },
    "./error-view": {
      "source": "./src/components/error-view/index.ts",
      "types": "./lib/typescript/src/components/error-view/index.d.ts",
      "default": "./lib/module/components/error-view/index.js"
    },
    "./form-field": {
      "source": "./src/components/form-field/index.ts",
      "types": "./lib/typescript/src/components/form-field/index.d.ts",
      "default": "./lib/module/components/form-field/index.js"
    },
    "./input-otp": {
      "source": "./src/components/input-otp/index.ts",
      "types": "./lib/typescript/src/components/input-otp/index.d.ts",
      "default": "./lib/module/components/input-otp/index.js"
    },
    "./label": {
      "source": "./src/components/label/index.ts",
      "types": "./lib/typescript/src/components/label/index.d.ts",
      "default": "./lib/module/components/label/index.js"
    },
    "./popover": {
      "source": "./src/components/popover/index.ts",
      "types": "./lib/typescript/src/components/popover/index.d.ts",
      "default": "./lib/module/components/popover/index.js"
    },
    "./pressable-feedback": {
      "source": "./src/components/pressable-feedback/index.ts",
      "types": "./lib/typescript/src/components/pressable-feedback/index.d.ts",
      "default": "./lib/module/components/pressable-feedback/index.js"
    },
    "./radio-group": {
      "source": "./src/components/radio-group/index.ts",
      "types": "./lib/typescript/src/components/radio-group/index.d.ts",
      "default": "./lib/module/components/radio-group/index.js"
    },
    "./scroll-shadow": {
      "source": "./src/components/scroll-shadow/index.ts",
      "types": "./lib/typescript/src/components/scroll-shadow/index.d.ts",
      "default": "./lib/module/components/scroll-shadow/index.js"
    },
    "./select": {
      "source": "./src/components/select/index.ts",
      "types": "./lib/typescript/src/components/select/index.d.ts",
      "default": "./lib/module/components/select/index.js"
    },
    "./skeleton": {
      "source": "./src/components/skeleton/index.ts",
      "types": "./lib/typescript/src/components/skeleton/index.d.ts",
      "default": "./lib/module/components/skeleton/index.js"
    },
    "./skeleton-group": {
      "source": "./src/components/skeleton-group/index.ts",
      "types": "./lib/typescript/src/components/skeleton-group/index.d.ts",
      "default": "./lib/module/components/skeleton-group/index.js"
    },
    "./spinner": {
      "source": "./src/components/spinner/index.ts",
      "types": "./lib/typescript/src/components/spinner/index.d.ts",
      "default": "./lib/module/components/spinner/index.js"
    },
    "./surface": {
      "source": "./src/components/surface/index.ts",
      "types": "./lib/typescript/src/components/surface/index.d.ts",
      "default": "./lib/module/components/surface/index.js"
    },
    "./switch": {
      "source": "./src/components/switch/index.ts",
      "types": "./lib/typescript/src/components/switch/index.d.ts",
      "default": "./lib/module/components/switch/index.js"
    },
    "./tabs": {
      "source": "./src/components/tabs/index.ts",
      "types": "./lib/typescript/src/components/tabs/index.d.ts",
      "default": "./lib/module/components/tabs/index.js"
    },
    "./text-field": {
      "source": "./src/components/text-field/index.ts",
      "types": "./lib/typescript/src/components/text-field/index.d.ts",
      "default": "./lib/module/components/text-field/index.js"
    },
    "./toast": {
      "source": "./src/components/toast/index.ts",
      "types": "./lib/typescript/src/components/toast/index.d.ts",
      "default": "./lib/module/components/toast/index.js"
    }
  },
  "files": [
    "src",
    "lib",
    "android",
    "ios",
    "cpp",
    "*.podspec",
    "react-native.config.js",
    "!ios/build",
    "!android/build",
    "!android/gradle",
    "!android/gradlew",
    "!android/gradlew.bat",
    "!android/local.properties",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__",
    "!**/.*"
  ],
  "scripts": {
    "example": "yarn workspace heroui-native-example",
    "test": "jest",
    "typecheck": "bash ./scripts/typecheck.sh",
    "lint": "eslint \"**/*.{js,ts,tsx}\"",
    "clean": "del-cli lib",
    "generate-exports": "node ./scripts/generate-exports.js",
    "validate-exports": "node ./scripts/validate-exports.js",
    "prepare": "yarn generate-exports && bob build",
    "changelog": "conventional-changelog -p angular -i CHANGELOG.md -s --commit-path .",
    "sync-version": "bash ./scripts/sync-version.sh",
    "release": "bumpp --execute='yarn changelog' --all"
  },
  "keywords": [
    "react-native",
    "ios",
    "android",
    "hero ui",
    "hero ui native"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/heroui-inc/heroui-native.git"
  },
  "author": "HeroUI <support@heroui.com> (https://github.com/heroui-inc)",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/heroui-inc/heroui-native/issues"
  },
  "homepage": "https://github.com/heroui-inc/heroui-native#readme",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "devDependencies": {
    "@commitlint/config-conventional": "^19.6.0",
    "@eslint/compat": "^1.2.7",
    "@eslint/eslintrc": "^3.3.0",
    "@eslint/js": "^9.22.0",
    "@evilmartians/lefthook": "^1.5.0",
    "@gorhom/bottom-sheet": "^5",
    "@react-native-community/cli": "latest",
    "@react-native/babel-preset": "0.78.2",
    "@react-native/eslint-config": "^0.78.0",
    "@types/jest": "^29.5.5",
    "@types/react": "^19.0.12",
    "babel-plugin-module-resolver": "^5.0.2",
    "babel-plugin-transform-remove-imports": "^1.8.0",
    "bumpp": "^9.10.2",
    "changelogithub": "^13.16.0",
    "commitlint": "^19.6.1",
    "conventional-changelog": "^7.1.1",
    "del-cli": "^5.1.0",
    "eslint": "^9.22.0",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-prettier": "^5.2.3",
    "jest": "^29.7.0",
    "prettier": "^3.0.3",
    "prettier-plugin-organize-imports": "^4.1.0",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-builder-bob": "^0.40.12",
    "react-native-gesture-handler": "^2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-worklets": "0.5.1",
    "tailwind-merge": "^3.4.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.1.17",
    "typescript": "^5.8.3",
    "uniwind": "1.2.4"
  },
  "peerDependencies": {
    "@gorhom/bottom-sheet": "^5",
    "react": ">=19.0.0",
    "react-native": ">=0.81.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": ">=4",
    "react-native-svg": "15.12.1",
    "react-native-worklets": "0.5.1",
    "tailwind-merge": "^3.4.0",
    "tailwind-variants": "^3.2.2"
  },
  "workspaces": [
    "example"
  ],
  "packageManager": "yarn@3.6.1",
  "jest": {
    "preset": "react-native",
    "modulePathIgnorePatterns": [
      "<rootDir>/example/node_modules",
      "<rootDir>/lib/"
    ]
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "bumpp": {
    "commit": true,
    "confirm": true,
    "push": true,
    "tag": true,
    "release": "prompt"
  },
  "prettier": {
    "quoteProps": "consistent",
    "singleQuote": true,
    "tabWidth": 2,
    "trailingComma": "es5",
    "useTabs": false,
    "plugins": [
      "prettier-plugin-organize-imports"
    ]
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      [
        "module",
        {
          "esm": true,
          "configFile": true
        }
      ],
      [
        "typescript",
        {
          "project": "tsconfig.build.json"
        }
      ]
    ]
  },
  "create-react-native-library": {
    "languages": "js",
    "type": "library",
    "version": "0.51.1"
  }
}
